#include <stdio.h>

int main()
{
    char a = -1;
    unsigned char b;

    /*
    컴퓨터가 음수를 저장하는 방법에는
    1의 보수와 2의 보수가 있다.

    -1을 char 변수에 넣고
    그 값을 unsigned char로 확인하면
    실제 비트값을 확인할 수 있다.

    1의 보수 : 11111110 (254)
    2의 보수 : 11111111 (255)

    그래서 값이 255이면
    이 컴퓨터는 2의 보수를 사용한다고 볼 수 있다.
    */

    b = (unsigned char)a;

    if (b == 255)
    {
        printf("This system uses two's complement.\n");
    }
    else
    {
        printf("This system uses one's complement.\n");
    }

    return 0;
}
